{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JackConnect",
  "version": "1.0.0",
  "identifier": "com.solomonos.jackconnect",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "cd .. && python3 -m http.server 8080"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "webviewInstallMode": { "type": "embedBootstrapper" }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "JackConnect — Solomon OS",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ]
  }
}