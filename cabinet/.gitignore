!data/example-text-your-mom/**
!data/vc-os/
!data/vc-os/**
data/vc-os/.cabinet-state/*
!data/vc-os/.cabinet-state/.gitkeep
data/vc-os/.agents/.conversations/
data/vc-os/.agents/.messages/
data/vc-os/.agents/.memory/
data/vc-os/.agents/.history/
data/vc-os/deal-flow/.cabinet-state/*
!data/vc-os/deal-flow/.cabinet-state/.gitkeep
data/vc-os/deal-flow/.agents/.conversations/
